---
const visibleSkillCount = 5;

const publications = [
  {
    title:
      "Fake News Detection With Credibility Scoring on Turkish Twitter Data (Revised and Expanded Version)",
    publisher: "IEEE",
    date: "Jul 30, 2025",
    href: "https://ieeexplore.ieee.org/document/11104062",
    skills: [
      "Python",
      "AI",
      "Machine Learning",
      "Data Analysis",
      "Misinformation",
      "Twitter Data",
    ],
    description:
      "Revised and expanded IEEE publication derived from the 2023 thesis research on fake news detection and credibility scoring for Turkish Twitter data.",
  },
  {
    title:
      "A Comparison of LSTM and BERT Based Models in Turkish Keyword Extraction",
    publisher: "DergiPark",
    date: "Mar 18, 2024",
    href: "https://dergipark.org.tr/tr/pub/bbmd/article/1454220",
    skills: ["Python", "AI", "NLP", "LSTM", "BERT", "Deep Learning"],
    description:
      "Comparative analysis assessing the effectiveness of LSTM and BERT models in Turkish keyword extraction.",
  },
  {
    title:
      "Fake News Detection with Credibility Scoring on Turkish Twitter Data",
    publisher: "Council of Higher Education (CoHE) Turkey",
    date: "Dec 31, 2023",
    href: "https://tez.yok.gov.tr/UlusalTezMerkezi/tezSorguSonucYeni.jsp",
    skills: [
      "Python",
      "AI",
      "Unsupervised Learning",
      "Twitter API",
      "Data Analysis",
      "Research",
    ],
    description:
      "Foundational thesis research later developed into the 2025 IEEE publication, focused on combating misinformation using unsupervised machine learning, manual labeling, and Twitter API-based analysis.",
  },
];
---

<section class="mt-10 border-t border-slate-200/80 pt-8 dark:border-zinc-800">
  <h1
    class="font-semibold text-2xl tracking-tight mb-3 text-slate-900 dark:text-slate-50"
  >
    Publications
  </h1>
  <div
    class="rounded-xl border border-slate-200 bg-white/60 p-5 dark:border-zinc-800 dark:bg-zinc-900/40"
  >
    {
      publications.map((publication, index) => (
        <details
          class={
            index === 0
              ? "group"
              : "group mt-8 border-t border-slate-200 pt-8 dark:border-zinc-800"
          }
        >
          <summary class="cursor-pointer list-none">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">
                  {publication.title}
                </h2>
                <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
                  {publication.publisher} • {publication.date}
                </p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {publication.skills.slice(0, visibleSkillCount).map((skill) => (
                    <span class="rounded-full border border-teal-300 bg-teal-50 px-2.5 py-1 text-xs text-teal-900 dark:border-teal-900/70 dark:bg-teal-950/30 dark:text-teal-200">
                      {skill}
                    </span>
                  ))}
                  {publication.skills.slice(visibleSkillCount).map((skill) => (
                    <span class="hidden rounded-full border border-teal-300 bg-teal-50 px-2.5 py-1 text-xs text-teal-900 group-open:inline-flex dark:border-teal-900/70 dark:bg-teal-950/30 dark:text-teal-200">
                      {skill}
                    </span>
                  ))}
                  {publication.skills.length > visibleSkillCount && (
                    <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs text-slate-500 group-open:hidden dark:border-zinc-700 dark:bg-zinc-800/70 dark:text-slate-400">
                      +{publication.skills.length - visibleSkillCount} more
                    </span>
                  )}
                </div>
              </div>
              <span class="mt-1 shrink-0 text-slate-400 transition group-open:rotate-180 dark:text-slate-500">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="h-5 w-5"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                    clip-rule="evenodd"
                  />
                </svg>
              </span>
            </div>
          </summary>
          <a
            href={publication.href}
            target="_blank"
            rel="noreferrer"
            class="mt-5 inline-flex items-center rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-teal-500 hover:text-teal-700 dark:border-zinc-700 dark:text-slate-200 dark:hover:border-teal-300 dark:hover:text-teal-300"
          >
            Show publication
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="ml-2 h-4 w-4"
            >
              <path d="M5 3a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2V9a1 1 0 10-2 0v6H5V5h6a1 1 0 100-2H5z" />
              <path d="M12.293 2.293a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L14 5.414V11a1 1 0 11-2 0V5.414L9.707 7.707A1 1 0 018.293 6.293l4-4z" />
            </svg>
          </a>
          <p class="mt-5 leading-7">{publication.description}</p>
        </details>
      ))
    }
  </div>
</section>
