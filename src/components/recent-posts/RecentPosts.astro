---
import RecentPostCard from './RecentPostCard.astro'
import type { BlogPost } from '@utils/blogPost'

type MarkdownPost = {
  frontmatter: BlogPost & { hidden?: boolean; [key: string]: unknown }
  url?: string
}

const allPosts = (Object.values(
  import.meta.glob('../../pages/blog/*.md', { eager: true })
) as MarkdownPost[]).map((post) => ({
  ...post,
  frontmatter: {
    ...post.frontmatter,
    date: new Date(post.frontmatter.date ?? new Date()),
  },
}))

const sortedPosts = allPosts
  .sort(
    (a, b) =>
      new Date(b.frontmatter.date).valueOf() -
      new Date(a.frontmatter.date).valueOf()
  )
  .filter((post) => !post.frontmatter.hidden)
---

<section class="flex flex-col max-w-7xl mx-auto">
  <div class="mb-4">
    <h1
      class="font-bold text-3xl tracking-tight mb-1 text-gray-700 dark:text-gray-50"
    >
      Recent Posts
    </h1>
  </div>
  <div class="flex gap-6 flex-col md:flex-row">
    {
      sortedPosts
        .slice(0, 3)
        .map((item) => (
          <RecentPostCard postUrl={item.url} post={item.frontmatter} />
        ))
    }
  </div>
</section>
