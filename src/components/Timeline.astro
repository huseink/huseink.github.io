---
const visibleSkillCount = 5;

const experienceGroups = [
  {
    company: "Mojob",
    url: "https://mojob.io",
    description: "Recruitment and staffing platform",
    roles: [
      {
        role: "Senior Full Stack Software Engineer",
        period: "August 2024 - Present (1 year 8 months)",
        location: "",
        skills: [
          "AI",
          "OpenAI",
          "Kubernetes",
          "PostgreSQL",
          "PGVector",
          "Vector Search",
          "Redis",
          "RabbitMQ",
          "Celery",
          "SSO",
          "SAML",
          "MFA",
          "Prometheus",
          "Grafana",
          "Loki",
          "Kibana",
          "K9s",
        ],
        bullets: [
          "Led development of AI-driven features in the recruitment pipeline, including CV parsing, attribute extraction, candidate profile generation, and automated translation in screening workflows.",
          "Owned architectural decisions and acted as a bridge between product and engineering, ensuring solutions aligned with business needs.",
          "Improved system stability, scalability, and performance through Kubernetes-based infrastructure and optimization of database queries and APIs.",
          "Reworked and strengthened authentication and security systems, implementing SSO, SAML, and MFA.",
          "Drove improvements in release processes and system reliability, introducing better versioning and deployment practices.",
        ],
      },
      {
        role: "Full Stack Software Engineer",
        period: "April 2022 - August 2024 (2 years 5 months)",
        location: "Oslo, Norway",
        skills: [
          "Vue.js",
          "Vuetify",
          "FastAPI",
          "OpenAI",
          "LangChain",
          "Llama 3",
          "Turborepo",
          "Docker",
          "Kubernetes",
          "AWS",
          "Elasticsearch",
          "Elasticsearch APM",
        ],
        bullets: [
          "Designed and implemented a custom authorization system across frontend and backend, tailored to recruiter workflows.",
          "Led the frontend migration from Vue 2 to Vue 3, improving performance and maintaining security across third-party dependencies.",
          "Led development of an AI-powered job description generator using OpenAI and Llama 3 via LangChain, built with FastAPI and Vue 3, including model tuning for improved output quality.",
          "Migrated a legacy repository into a modern monorepo using Turborepo, improving code organization and development workflows.",
          "Improved containerization and deployment processes using Docker, Kubernetes, and AWS, focusing on performance and reliability.",
        ],
      },
      {
        role: "Junior Full Stack Software Engineer",
        period: "October 2021 - April 2022 (7 months)",
        location: "Oslo, Norway",
        skills: [
          "JavaScript",
          "TypeScript",
          "Vue.js",
          "REST APIs",
          "Frontend",
          "Backend",
          "PostgreSQL",
        ],
        bullets: [
          "Worked across frontend and backend, contributing to features and improvements that supported system stability and product development.",
          "Collaborated across teams to ensure smooth integration between frontend and backend components.",
          "Gained hands-on experience with full stack development, working with APIs, data handling, and user-facing features.",
        ],
      },
    ],
  },
  {
    company: "Sechard",
    url: "https://sechard.com",
    description: "Security hardening platform",
    roles: [
      {
        role: "Full Stack Software Engineer",
        period: "August 2020 - October 2021 (1 year 3 months)",
        location: "Istanbul, Türkiye",
        skills: [
          "Security Hardening",
          "Angular",
          "Node.js",
          "Express.js",
          "MongoDB",
          "Apache Guacamole",
          "Docker",
          "Grafana",
          "Prometheus",
          "Nginx",
          "JavaScript",
          "Python",
        ],
        bullets: [
          "Implemented remote access functionality using Apache Guacamole, enabling users to connect via RDP/VNC; led the design and development of both frontend and backend components.",
          "Integrated system monitoring capabilities, allowing users to view active server performance and key metrics through Grafana.",
          "Containerized backend microservices using Docker to improve portability and deployment consistency.",
          "Identified and resolved security vulnerabilities across Nginx configurations, Docker images, and application code.",
        ],
      },
    ],
  },
];

const educationGroups = [
  {
    school: "Trakya University",
    url: "https://www.trakya.edu.tr/",
    degrees: [
      {
        degree: "Master of Science - MS, Computer Engineering",
        period: "September 2021 - August 2023",
        grade: "89.52 / 100",
        skills: [
          "Machine Learning",
          "AI",
          "NLP",
          "Python",
          "Research",
          "LSTM",
          "BERT",
        ],
      },
      {
        degree: "Bachelor of Engineering - BE, Computer Engineering",
        period: "2017 - July 2021",
        grade: "3.63 / 4.00",
        skills: [
          "Computer Engineering",
          "Software Engineering",
          "Algorithms",
          "Data Structures",
          "Python",
          "JavaScript",
        ],
      },
    ],
  },
];
---

<section class="mt-7">
  <h1
    class="font-semibold text-2xl tracking-tight mb-5 text-slate-900 dark:text-slate-50"
  >
    Experience
  </h1>
  <div class="space-y-10">
    {
      experienceGroups.map((group) => (
        <section class="grid gap-4 border-b border-slate-200/80 pb-10 last:border-b-0 dark:border-zinc-800 md:grid-cols-[11rem_1fr]">
          <div>
            <a
              href={group.url}
              target="_blank"
              rel="noreferrer"
              class="text-lg font-semibold text-slate-700 transition hover:text-teal-700 dark:text-slate-300 dark:hover:text-teal-300"
            >
              {group.company}
            </a>
            <p class="mt-2 max-w-[10rem] text-sm leading-6 text-slate-500 dark:text-slate-400">
              {group.description}
            </p>
          </div>
          <div class="space-y-4">
            {group.roles.map((item) => (
              <details class="group rounded-xl border border-slate-200 bg-white/60 px-5 py-4 open:bg-white/90 dark:border-zinc-800 dark:bg-zinc-900/40 dark:open:bg-zinc-900/70">
                <summary class="cursor-pointer list-none">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="text-lg font-medium text-slate-900 dark:text-slate-100">
                        {item.role}
                      </h3>
                      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
                        {item.period}
                      </p>
                      {item.location && (
                        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
                          {item.location}
                        </p>
                      )}
                      <div class="mt-3 flex flex-wrap gap-2">
                        {item.skills.slice(0, visibleSkillCount).map((skill) => (
                          <span class="rounded-full border border-teal-200 bg-teal-50/70 px-2.5 py-1 text-xs text-teal-800 dark:border-teal-900/70 dark:bg-teal-950/30 dark:text-teal-200">
                            {skill}
                          </span>
                        ))}
                        {item.skills.slice(visibleSkillCount).map((skill) => (
                          <span class="hidden rounded-full border border-teal-200 bg-teal-50/70 px-2.5 py-1 text-xs text-teal-800 group-open:inline-flex dark:border-teal-900/70 dark:bg-teal-950/30 dark:text-teal-200">
                            {skill}
                          </span>
                        ))}
                        {item.skills.length > visibleSkillCount && (
                          <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs text-slate-500 group-open:hidden dark:border-zinc-700 dark:bg-zinc-800/70 dark:text-slate-400">
                            +{item.skills.length - visibleSkillCount} more
                          </span>
                        )}
                      </div>
                    </div>
                    <span class="mt-1 shrink-0 text-slate-400 transition group-open:rotate-180 dark:text-slate-500">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                        class="h-5 w-5"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    </span>
                  </div>
                </summary>
                <ul class="mt-4 space-y-3 border-t border-slate-200 pt-4 text-slate-600 dark:border-zinc-800 dark:text-slate-300">
                  {item.bullets.map((bullet) => (
                    <li class="leading-7">{bullet}</li>
                  ))}
                </ul>
              </details>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</section>

<section class="mt-10 border-t border-slate-200/80 pt-8 dark:border-zinc-800">
  <h1
    class="font-semibold text-2xl tracking-tight mb-5 text-slate-900 dark:text-slate-50"
  >
    Education
  </h1>
  <div class="space-y-10">
    {
      educationGroups.map((group) => (
        <section class="grid gap-4 border-b border-slate-200/80 pb-10 last:border-b-0 dark:border-zinc-800 md:grid-cols-[11rem_1fr]">
          <div>
            <a
              href={group.url}
              target="_blank"
              rel="noreferrer"
              class="text-lg font-semibold text-slate-700 transition hover:text-teal-700 dark:text-slate-300 dark:hover:text-teal-300"
            >
              {group.school}
            </a>
          </div>
          <div class="space-y-4">
            {group.degrees.map((item) => (
              <details class="group rounded-xl border border-slate-200 bg-white/60 px-5 py-5 open:bg-white/90 dark:border-zinc-800 dark:bg-zinc-900/40 dark:open:bg-zinc-900/70">
                <summary class="cursor-pointer list-none">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="text-lg font-medium text-slate-900 dark:text-slate-100">
                        {item.degree}
                      </h3>
                      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
                        {item.period}
                      </p>
                      <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
                        Grade: {item.grade}
                      </p>
                      <div class="mt-3 flex flex-wrap gap-2">
                        {item.skills.slice(0, visibleSkillCount).map((skill) => (
                          <span class="rounded-full border border-teal-200 bg-teal-50/70 px-2.5 py-1 text-xs text-teal-800 dark:border-teal-900/70 dark:bg-teal-950/30 dark:text-teal-200">
                            {skill}
                          </span>
                        ))}
                        {item.skills.slice(visibleSkillCount).map((skill) => (
                          <span class="hidden rounded-full border border-teal-200 bg-teal-50/70 px-2.5 py-1 text-xs text-teal-800 group-open:inline-flex dark:border-teal-900/70 dark:bg-teal-950/30 dark:text-teal-200">
                            {skill}
                          </span>
                        ))}
                        {item.skills.length > visibleSkillCount && (
                          <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs text-slate-500 group-open:hidden dark:border-zinc-700 dark:bg-zinc-800/70 dark:text-slate-400">
                            +{item.skills.length - visibleSkillCount} more
                          </span>
                        )}
                      </div>
                    </div>
                    <span class="mt-1 shrink-0 text-slate-400 transition group-open:rotate-180 dark:text-slate-500">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                        class="h-5 w-5"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    </span>
                  </div>
                </summary>
              </details>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</section>
