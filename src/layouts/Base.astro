---
import Header from "@layouts/Header.astro";
import Footer from "@layouts/Footer.astro";
import { APP_CONFIG } from "@utils/config";
import ThemeScript from "@components/theme/ThemeScript.astro";
import "../styles/global.css";
export interface Props {
  head: {
    title: string;
    description: string;
  };
  includeCodeStyles?: boolean;
}
const {
  head: { title, description },
  includeCodeStyles = false,
} = Astro.props as Props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={APP_CONFIG.author} />
    <link type="image/png" sizes="16x16" rel="icon" href="/favicon-16.png" />
    <link type="image/png" sizes="32x32" rel="icon" href="/favicon-32.png" />
    <link type="image/png" sizes="96x96" rel="icon" href="/favicon-96.png" />
    {includeCodeStyles && <link href="/code-syntax-highlight.css" rel="stylesheet" />}
    {APP_CONFIG.analyticsMeasurementId && (
      <>
        <script
          is:inline
          src={`https://www.googletagmanager.com/gtag/js?id=${APP_CONFIG.analyticsMeasurementId}`}
        ></script>
        <script
          is:inline
          define:vars={{ measurementId: APP_CONFIG.analyticsMeasurementId }}
        >
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag("js", new Date());
          gtag("config", measurementId);
        </script>
      </>
    )}
  </head>
  <body
    class="font-monsterrat min-h-screen bg-stone-50 text-slate-700 flex flex-col items-center dark:bg-zinc-950 dark:text-slate-400"
  >
    <div class="w-full max-w-3xl flex-grow px-6 pb-10 sm:px-8 md:px-0">
      <Header />
      <main id="main-content">
        <slot />
      </main>
      <Footer />
    </div>
    <ThemeScript />
  </body>
</html>

<style is:global>
  ::selection {
    background: rgba(13, 148, 136, 0.18);
  }

  html.theme-animating *,
  html.theme-animating *::before,
  html.theme-animating *::after {
    transition:
      background-color 280ms ease,
      border-color 280ms ease,
      color 280ms ease,
      fill 280ms ease,
      stroke 280ms ease,
      box-shadow 280ms ease;
  }
</style>
